# Server
API_KEY=your-secret-api-key-here
PORT=8000

# Tauon Poller (local only)
TAUON_URL=http://localhost:7814
DEPLOY_URL=https://your-deploy-url.deno.dev
POLL_INTERVAL_MS=10000

# LastFM (direct API - server-side)
LASTFM_API_KEY=your-lastfm-api-key
LASTFM_USERNAME=your-lastfm-username

# Spotify (coming soon)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Tidal (coming soon)
# TIDAL_CLIENT_ID=
# TIDAL_CLIENT_SECRET=

# Source cache TTL in milliseconds (default: 30000, min: 5000)
# Applies to Last.fm and Spotify API response caching
# SOURCE_CACHE_TTL_MS=30000

# Logging
LOG_LEVEL=info
